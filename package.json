{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node_modules/.bin/next dev",
    "build": "node_modules/.bin/prisma generate && node_modules/.bin/next build",
    "start": "node_modules/.bin/next start",
    "lint": "node_modules/.bin/next lint",
    "postinstall": "node_modules/.bin/prisma generate",
    "prisma:generate": "node_modules/.bin/prisma generate",
    "prisma:migrate": "node_modules/.bin/prisma migrate dev",
    "prisma:studio": "node_modules/.bin/prisma studio",
    "prisma:seed": "node_modules/.bin/ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts",
    "db:push": "node_modules/.bin/prisma db push",
    "db:reset": "node_modules/.bin/prisma migrate reset --force"
  },
