    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cloudinary": "^2.4.0",
    "embla-carousel-react": "^8.1.8",
    "framer-motion": "^11.3.0",
    "gsap": "^3.12.5",
    "lucide-react": "^0.396.0",
