# Example Environment Variables

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Database (PostgreSQL)
# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/portfolio?schema=public"

# NextAuth
# Generate one via `openssl rand -base64 32` or `npx auth secret`
NEXTAUTH_SECRET="your-super-secret-nextauth-key-change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Admin Credentials
ADMIN_EMAIL="admin@portfolio.com"
# Bcrypt hash of 'password' for local dev. Use a strong password hash in production!
ADMIN_PASSWORD_HASH="$2a$12$Z/bW9.M11m.q49A5O5sJ1.Kx4Q.2Z8K.k2sJ3/Q4.U3k0/H1n3M4u"

# Cloudinary (for media uploads)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="portfolio_preset"
